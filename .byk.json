{
    "$priority": -1,

    "git": {
        "查看本地标签": "git tag",
        "查看远程库标签": "git ls-remote --tags origin",
        "推送标签到远程库": "git push origin --tags",
        "撤销上一次提交": "git reset --soft HEAD~1"
    },

    "卸载":{
        "byk": "pip uninstall byk",
        "bykpy": "pip uninstall bykpy -y",
        "byk-hello": "pip uninstall byk-hello -y",
        "byk-ai": "pip uninstall byk-ai -y",
        "byk-pick": "pip uninstall byk-pick -y",
        "byk-lansend": "pip uninstall byk-lansend -y",
        "byk-slide": "pip uninstall byk-slide -y"
    },

    "安装":{
        "byk": "pip install byk",
        "byk-hello": {"$cmd": "pip install -e .","$cwd": "./byk-hello"},
        "byk-ai": {"$cmd": "pip install -e .","$cwd": "./byk-ai"},
        "byk-pick": {"$cmd": "pip install -e .","$cwd": "./byk-pick"},
        "byk-lansend": {"$cmd": "pip install -e .","$cwd": "./byk-lansend"},
        "byk-slide": {"$cmd": "pip install -e .","$cwd": "./byk-slide"},
        "bykpy": {"$cmd": "pip install -e .","$cwd": "./bykpy"}
    },

    "发布": {
        "检查上传的文件": "twine check dist/*",
        "上传到PyPI": "twine upload dist/*"
    },

    "清理文件": "find . -type d \\( -name '__pycache__' -o -name '.pytest_cache' \\) -exec rm -rf {} +"
}